# =============================================================================
# mcp-core123-vendor-api — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# -----------------------------------------------------------------------------
# Auth — pre-obtained tokens (consumed by the MCP server)
# -----------------------------------------------------------------------------
# Obtain these by running the Playwright helper (see below) OR by logging
# in via browser DevTools manually and copying POST /v1/auth/login response.
# When refresh_token expires, rerun the helper and restart MCP.
VENDOR_ACCESS_TOKEN=
VENDOR_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Auth helper (used ONLY by scripts/auth/playwright_login.py)
# -----------------------------------------------------------------------------
# The helper launches a real browser; you type the captcha, it captures
# the tokens and writes VENDOR_ACCESS_TOKEN / VENDOR_REFRESH_TOKEN above.
# Email + password are best-effort prefilled; leave blank to type manually.
VENDOR_EMAIL=
VENDOR_PASSWORD=
VENDOR_ID=
